{
  "buildCommand": "vite build && cp -r api dist/api",
  "outputDirectory": "dist",
  "devCommand": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}